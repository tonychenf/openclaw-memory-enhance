# Mem0 Agent Setup - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ===================
# 必需配置
# ===================

# LLM API Key（从 SiliconFlow 或 OpenAI 获取）
OPENAI_API_KEY=your-api-key-here

# API Base URL（可选，默认使用 SiliconFlow）
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ===================
# 可选配置
# ===================

# Qdrant 向量数据库地址（可选，默认 localhost:6333）
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Agent 标识（可选，默认 main）
# AGENT_NAME=main

# 用户标识（必填！）
# 用于在 Mem0 中区分不同用户，单用户部署时设为你的用户名或任意唯一标识
# 多用户环境下，每个用户应设置不同的值，以实现记忆隔离
MEM0_USER_ID=owner
